# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Cloudinary Configuration
# Get these from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key_here
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=smart-construction

# Note: CLOUDINARY_API_SECRET should NEVER be in frontend .env
# It should only be in backend .env for server-side operations
